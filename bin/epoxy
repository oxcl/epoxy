#!/usr/bin/env bash
# epoxy - launch a nested somewm compositor via somewm-client test.
#
# Uses the built-in test orchestrator for lifecycle management.

set -euo pipefail

CONFIG="${EPoxy_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/epoxy/somewm/rc.lua}"
INSTANCE_NAME="epoxy"

# Clean up any previous instance
somewm-client test stop --name "$INSTANCE_NAME" 2>/dev/null || true

# Launch (headless by default — wayland nested is broken in this env)
echo "Starting somewm..."
WLR_RENDERER=pixman somewm-client test start \
    --name "$INSTANCE_NAME" \
    --host headless \
    --config "$CONFIG"

echo ""
echo "To stop:  somewm-client test stop --name $INSTANCE_NAME"
echo "To eval:  somewm-client test eval --name $INSTANCE_NAME 'return #screen'"
echo "To logs:  somewm-client test logs --name $INSTANCE_NAME -f"
